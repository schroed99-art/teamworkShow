<!--
  Splash-screen icon for the Android 12+ SplashScreen API.
  Wraps the Teamwork Show logo with an inset so it stays inside the
  circular icon safe-zone (avoids clipping the outer figures).
-->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:drawable="@drawable/ic_teamwork_logo"
    android:insetLeft="24dp"
    android:insetTop="24dp"
    android:insetRight="24dp"
    android:insetBottom="24dp" />
