<?xml version="1.0" encoding="utf-8"?>
<!-- Landscape / TV variant of the stage. Same view IDs as the portrait layout
     (MainActivity.findViewById relies on them); landscape-specific spacing comes
     from values-land/dimens.xml, plus the ticker gets horizontal insets here. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- The stage(s) — see the portrait layout. Orientation, weights and visibility
         come from the synced zone tree at runtime (MainActivity.buildStages), so
         this file only provides the empty container; orientation, weights and
         nesting are all built in code. -->
    <LinearLayout
        android:id="@+id/stageContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical" />

    <!-- Discreet version label, top-right (also the maintenance tap corner) -->
    <TextView
        android:id="@+id/versionLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="@dimen/version_margin_top"
        android:layout_marginEnd="@dimen/version_margin_end"
        android:textColor="#66FFFFFF"
        android:textSize="11sp"
        android:shadowColor="#000000"
        android:shadowRadius="4"
        android:shadowDx="0"
        android:shadowDy="0"
        android:contentDescription="@null" />

    <!-- Update-available badge, just below the version label. Appears only when
         a newer signed APK is published; tapping it starts the download+install.
         The operator triggers it deliberately, so no system prompt ever overlays
         a running presentation. -->
    <TextView
        android:id="@+id/updateBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="@dimen/update_badge_margin_top"
        android:layout_marginEnd="@dimen/version_margin_end"
        android:paddingHorizontal="8dp"
        android:paddingVertical="3dp"
        android:background="#D81B60"
        android:textColor="#FFFFFFFF"
        android:textSize="11sp"
        android:visibility="gone"
        android:contentDescription="@null" />

    <!-- Notices ticker, bottom (from the device's widget settings).
         Continuous right-to-left scroller: the inner text is translated across
         the full-width bar (see startTicker), so it always scrolls regardless
         of text length — unlike ellipsize=marquee, which only scrolls when the
         text overflows the view and is unreliable. -->
    <FrameLayout
        android:id="@+id/noticesBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="@dimen/notices_bar_margin_bottom"
        android:layout_marginStart="@dimen/notices_bar_margin_horizontal"
        android:layout_marginEnd="@dimen/notices_bar_margin_horizontal"
        android:background="#66000000"
        android:paddingVertical="@dimen/notices_bar_padding_vertical"
        android:clipChildren="true"
        android:clipToPadding="true"
        android:visibility="gone">

        <TextView
            android:id="@+id/noticesText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:singleLine="true"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp"
            android:contentDescription="@null" />
    </FrameLayout>

    <!-- Download screen: shown while media is being downloaded (over the start image) -->
    <FrameLayout
        android:id="@+id/downloadOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/splashscreen_v3"
            android:scaleType="centerCrop"
            android:contentDescription="@null" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="48dp"
            android:paddingBottom="90dp">

            <TextView
                android:id="@+id/downloadStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFFFF"
                android:textSize="16sp"
                android:shadowColor="#000000"
                android:shadowRadius="6"
                android:layout_marginBottom="14dp" />

            <ProgressBar
                android:id="@+id/downloadProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/brand_magenta"
                android:progressBackgroundTint="#33FFFFFF" />

        </LinearLayout>

    </FrameLayout>

    <LinearLayout
        android:id="@+id/pairingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#FF0A0A0A"
        android:paddingHorizontal="40dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pairing_title"
            android:textColor="#FFFFFFFF"
            android:textSize="22sp"
            android:layout_marginBottom="18dp" />

        <TextView
            android:id="@+id/pairingCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:textColor="@color/brand_magenta"
            android:textSize="64sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="22dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pairing_hint_overlay"
            android:gravity="center"
            android:textColor="#FFB0B0B0"
            android:textSize="16sp"
            android:layout_marginBottom="26dp" />

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminateTint="@color/brand_magenta" />

    </LinearLayout>

</FrameLayout>
