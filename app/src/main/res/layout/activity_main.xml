<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- A/B ImageViews for crossfade between images -->
    <ImageView
        android:id="@+id/imageViewA"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:alpha="0"
        android:contentDescription="@null" />

    <ImageView
        android:id="@+id/imageViewB"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:alpha="0"
        android:contentDescription="@null" />

    <!-- TextureView mode required for alpha-based crossfade -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        app:use_controller="false"
        app:resize_mode="fit"
        app:surface_type="texture_view" />

    <!-- Empty state: full-bleed branded start image, shown when no media is present -->
    <ImageView
        android:id="@+id/emptyView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/startbild"
        android:scaleType="centerCrop"
        android:contentDescription="@string/logo_desc"
        android:visibility="gone" />

    <!-- Discreet version label, always on top, bottom edge -->
    <TextView
        android:id="@+id/versionLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="6dp"
        android:textColor="#66FFFFFF"
        android:textSize="10sp"
        android:shadowColor="#000000"
        android:shadowRadius="4"
        android:shadowDx="0"
        android:shadowDy="0"
        android:contentDescription="@null" />

</FrameLayout>
