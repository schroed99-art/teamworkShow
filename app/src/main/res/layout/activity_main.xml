<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- A/B ImageViews for crossfade between images -->
    <ImageView
        android:id="@+id/imageViewA"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:alpha="0"
        android:contentDescription="@null" />

    <ImageView
        android:id="@+id/imageViewB"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:alpha="0"
        android:contentDescription="@null" />

    <!-- TextureView mode required for alpha-based crossfade -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        app:use_controller="false"
        app:resize_mode="fit"
        app:surface_type="texture_view" />

    <!-- Empty state: full-bleed branded start image, shown when no media is present -->
    <ImageView
        android:id="@+id/emptyView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/startbild"
        android:scaleType="centerCrop"
        android:contentDescription="@string/logo_desc"
        android:visibility="gone" />

    <!-- Weather interstitial: configurable background + scrim + a container whose children
         (city / forecast / clock / free texts) are built at runtime from the layout config. -->
    <FrameLayout
        android:id="@+id/weatherView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:alpha="0">

        <ImageView
            android:id="@+id/wxBg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="@null" />

        <View
            android:id="@+id/wxScrim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#000000"
            android:alpha="0" />

        <FrameLayout
            android:id="@+id/wxLayer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="24dp" />

    </FrameLayout>

    <!-- Discreet preloader line: shows elapsed time of the current slide -->
    <ProgressBar
        android:id="@+id/slideProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_gravity="bottom"
        android:max="1000"
        android:progress="0"
        android:progressTint="@color/brand_magenta"
        android:progressBackgroundTint="#22FFFFFF"
        android:visibility="gone" />

    <!-- Discreet version label, top-right (also the maintenance tap corner) -->
    <TextView
        android:id="@+id/versionLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="10dp"
        android:textColor="#66FFFFFF"
        android:textSize="11sp"
        android:shadowColor="#000000"
        android:shadowRadius="4"
        android:shadowDx="0"
        android:shadowDy="0"
        android:contentDescription="@null" />

    <!-- Notices ticker, bottom (from the device's widget settings) -->
    <TextView
        android:id="@+id/noticesBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="6dp"
        android:background="#66000000"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:textColor="#FFFFFFFF"
        android:textSize="15sp"
        android:singleLine="true"
        android:ellipsize="marquee"
        android:marqueeRepeatLimit="marquee_forever"
        android:visibility="gone"
        android:contentDescription="@null" />

    <!-- Download screen: shown while media is being downloaded (over the start image) -->
    <FrameLayout
        android:id="@+id/downloadOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/splashscreen_v3"
            android:scaleType="centerCrop"
            android:contentDescription="@null" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="48dp"
            android:paddingBottom="90dp">

            <TextView
                android:id="@+id/downloadStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFFFF"
                android:textSize="16sp"
                android:shadowColor="#000000"
                android:shadowRadius="6"
                android:layout_marginBottom="14dp" />

            <ProgressBar
                android:id="@+id/downloadProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/brand_magenta"
                android:progressBackgroundTint="#33FFFFFF" />

        </LinearLayout>

    </FrameLayout>

    <LinearLayout
        android:id="@+id/pairingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#FF0A0A0A"
        android:paddingHorizontal="40dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pairing_title"
            android:textColor="#FFFFFFFF"
            android:textSize="22sp"
            android:layout_marginBottom="18dp" />

        <TextView
            android:id="@+id/pairingCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:textColor="@color/brand_magenta"
            android:textSize="64sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="22dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pairing_hint_overlay"
            android:gravity="center"
            android:textColor="#FFB0B0B0"
            android:textSize="16sp"
            android:layout_marginBottom="26dp" />

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminateTint="@color/brand_magenta" />

    </LinearLayout>

</FrameLayout>
