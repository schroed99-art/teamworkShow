<?xml version="1.0" encoding="utf-8"?>
<!--
  One slideshow stage. Included once per zone (see activity_main.xml), so the IDs
  in here are NOT unique across the window: always look them up scoped to the
  include's root view (Stage does), never via Activity.findViewById.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- A/B ImageViews for crossfade between images -->
    <ImageView
        android:id="@+id/imageViewA"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:alpha="0"
        android:contentDescription="@null" />

    <ImageView
        android:id="@+id/imageViewB"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:alpha="0"
        android:contentDescription="@null" />

    <!-- TextureView mode required for alpha-based crossfade -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        app:use_controller="false"
        app:resize_mode="fit"
        app:surface_type="texture_view" />

    <!-- Empty state: branded "no presentation yet" screen (logo + hint + version),
         shown for a freshly paired device or an assigned-but-empty presentation. -->
    <LinearLayout
        android:id="@+id/emptyView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#0F172A"
        android:padding="24dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_teamwork_logo"
            android:layout_marginBottom="22dp"
            android:contentDescription="@string/logo_desc" />

        <View
            android:layout_width="48dp"
            android:layout_height="3dp"
            android:background="@color/brand_magenta"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/emptyTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/empty_title"
            android:textColor="#F1F5F9"
            android:textStyle="bold"
            android:textSize="26sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/emptyHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/empty_hint"
            android:textColor="#94A3B8"
            android:textSize="15sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.3"
            android:layout_marginTop="10dp"
            android:paddingHorizontal="16dp" />

        <TextView
            android:id="@+id/emptyVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#64748B"
            android:textSize="12sp"
            android:layout_marginTop="26dp" />

    </LinearLayout>

    <!-- Weather interstitial: configurable background + scrim + a container whose children
         (city / forecast / clock / free texts) are built at runtime from the layout config. -->
    <FrameLayout
        android:id="@+id/weatherView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:alpha="0">

        <ImageView
            android:id="@+id/wxBg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="@null" />

        <View
            android:id="@+id/wxScrim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#000000"
            android:alpha="0" />

        <FrameLayout
            android:id="@+id/wxLayer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="@dimen/weather_padding" />

    </FrameLayout>

    <!-- News slide: a file-less message. Text auto-sizes, so the same slide stays
         legible whether it fills the screen or only a narrow zone. -->
    <FrameLayout
        android:id="@+id/newsView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0F172A"
        android:alpha="0">

        <!-- Optional background image + dark scrim so the message stays legible. -->
        <ImageView
            android:id="@+id/newsBg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:contentDescription="@null" />

        <View
            android:id="@+id/newsScrim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#8C0F172A"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:padding="@dimen/weather_padding">

            <View
                android:layout_width="64dp"
                android:layout_height="4dp"
                android:background="@color/brand_magenta"
                android:layout_marginBottom="14dp" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/newsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="3"
                android:textColor="#FFFFFFFF"
                android:textStyle="bold"
                android:textSize="34sp"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="14sp"
                app:autoSizeMaxTextSize="44sp"
                android:contentDescription="@null" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/newsBody"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="12dp"
                android:textColor="#FFCBD5E1"
                android:textSize="20sp"
                android:lineSpacingMultiplier="1.15"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="11sp"
                app:autoSizeMaxTextSize="26sp"
                android:contentDescription="@null" />

        </LinearLayout>
    </FrameLayout>

    <!-- Discreet preloader line: shows elapsed time of the current slide -->
    <ProgressBar
        android:id="@+id/slideProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="@dimen/slide_progress_height"
        android:layout_gravity="bottom"
        android:max="1000"
        android:progress="0"
        android:progressTint="@color/brand_magenta"
        android:progressBackgroundTint="#22FFFFFF"
        android:visibility="gone" />

</FrameLayout>
