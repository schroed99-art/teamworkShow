# TeamworkShow backend config (env format, for All-Inkl & other shared hosting).
#
# Copy this to a file that lives OUTSIDE the web root (e.g. one level above the
# docroot: <parent>/teamworkshow-private/app.env), fill in the real values, and
# point the app at it via the TW_CONFIG environment variable (web: .user.ini,
# CLI/cron: `export TW_CONFIG=…`). tw_config() also auto-detects
# <parent-of-docroot>/teamworkshow-private/app.env and repo-level config/app.env.
#
# NEVER commit the filled-in file — config/*.env is gitignored. On the legacy VM,
# server/php/config.php still takes precedence, so nothing there changes.

DB_HOST=localhost
DB_NAME=
DB_USER=
DB_PASS=

# Empty => weather.php returns a clear stub ({"stub":true}) and the gate stays green.
OPENWEATHER_API_KEY=

# Dashboard-Admin login password AND the X-Admin-Token for the API / integration gate.
ADMIN_PASSWORD=

# Secret token for the URL-triggered device monitor (All-Inkl KAS cron calls
# https://…/device_monitor.php?key=CRON_KEY). Empty => the web call is denied.
CRON_KEY=

