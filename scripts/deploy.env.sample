# Deploy target for scripts/deploy.sh + scripts/publish-apk.sh.
# Copy to scripts/deploy.env (gitignored) and edit for the host you want to push to.
# Without scripts/deploy.env, both scripts default to the legacy VM.

# ---- Legacy VM (default when this file is absent) ----
# DEPLOY_HOST="192.168.178.207"
# DEPLOY_USER="root"
# DEPLOY_PATH="/var/www/html/teamworkshow"
# DEPLOY_KEY="$HOME/.ssh/teamworkshow_deploy"
# DEPLOY_PORT="22"
# DEPLOY_PRIVATE_DIR="/var/www/teamworkshow-apk"   # APK dir, outside the web root
# DEPLOY_CHOWN="www-data:www-data"                 # empty on hosts without root

# ---- All-Inkl (fill in from KAS: SSH host, user wXXXXXXX, docroot path) ----
DEPLOY_HOST="sshXXX.kasserver.com"
DEPLOY_USER="wXXXXXXX"
DEPLOY_PATH="/www/htdocs/wXXXXXXX/teamworkshow.itandmedia-solution.de"
DEPLOY_KEY="$HOME/.ssh/teamworkshow_deploy"
DEPLOY_PORT="22"
# APK private dir one level above the docroot (create it in KAS / via SSH).
DEPLOY_PRIVATE_DIR="/www/htdocs/wXXXXXXX/teamworkshow-apk"
# No root on shared hosting -> leave empty to skip chown (files are owned by the SSH user).
DEPLOY_CHOWN=""
